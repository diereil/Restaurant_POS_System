{
  "version": 2,
  "builds": [
    {
      "src": "pos-backend/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "pos-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "pos-backend/app.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}