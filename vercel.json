{
  "version": 2,
  "builds": [
    {
      "src": "pos-backend/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "pos-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "pos-backend/app.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "pos-frontend/assets/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|svg|ico|webp|mp3|wav))",
      "dest": "pos-frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "pos-frontend/index.html"
    }
  ]
}